# AssurAssistance Backend – copy to .env and fill in values
# For Hostinger VPS: DB_HOST=localhost, DB_* from the database you created

PORT=3000
NODE_ENV=production

# Database (use localhost when DB is on same VPS)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=assurassistance
DB_USER=assurapp
DB_PASSWORD=your_db_password

# JWT – use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-at-least-32-characters
JWT_EXPIRES_IN=1h

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="AssurAssistance <your-email@gmail.com>"

# URLs
BASE_URL=https://your-backend-domain.com
FRONTEND_URL=https://assurassistancepro.org
# Public API origin (no /api) — used for absolute URLs to /uploads (e.g. certificate partner logos)
PUBLIC_API_URL=https://your-backend-domain.com

# Certificate contact lines (general inquiries + WhatsApp on every certificate)
CERTIFICATE_GENERAL_PHONE=+225 27 22 22 82 60
CERTIFICATE_WHATSAPP_PHONE=+225 07 18 92 31 94
# CERTIFICATE_EMERGENCY_PHONE=+91 62916 62954
# CERTIFICATE_WEBSITE_URL=https://www.assurassistance.org

# Optional
ADMIN_EMAIL=admin@example.com
BCRYPT_ROUNDS=12

# Per-IP global rate limit on /api (express-rate-limit). 600 req / 15 min by default.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=600

# Per-API-key default requests-per-minute (per-key override available on each key row).
API_KEY_DEFAULT_RPM=120

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Comma-separated list of additional CORS origins. The hardcoded production origins are
# always allowed; this is for partner / staging / preview domains.
# CORS_ORIGINS=https://partner.example.com,https://staging.assurassistancepro.org
