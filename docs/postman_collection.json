        },
        {
          "name": "Change case status",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/cases/4821/status", "host": ["{{baseUrl}}"], "path": ["cases","4821","status"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"status\": \"Cancelled\" }" }
