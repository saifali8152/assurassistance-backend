                { "key": "startDate", "value": "2026-01-01" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "Invoices by region — CSV",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/invoice-ledger/export?regionBy=residence", "host": ["{{baseUrl}}"], "path": ["invoice-ledger","export"], "query": [{"key":"regionBy","value":"residence"}] } }
        }
      ]
    },
    {
      "name": "Agents (admin / sub-admin JWT)",
      "description": "Agency-management endpoints. JWT only — no API-key scope grants access. Uses {{jwt}}.",
