            "url": { "raw": "{{baseUrl}}/cases/4821", "host": ["{{baseUrl}}"], "path": ["cases","4821"] }
          }
        },
        {
          "name": "Confirm sale",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/cases/4821/confirm-sale", "host": ["{{baseUrl}}"], "path": ["cases","4821","confirm-sale"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"premium_amount\": 25000, \"tax\": 0, \"total\": 25000 }" }
          }
        },
        {
          "name": "Cancel case",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/cases/4821/cancel", "host": ["{{baseUrl}}"], "path": ["cases","4821","cancel"] }
          }
        },
        {
          "name": "Update case",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/cases/4821/update", "host": ["{{baseUrl}}"], "path": ["cases","4821","update"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traveller\": { \"first_name\": \"Aïcha\", \"last_name\": \"Diallo\", \"phone\": \"+225...\", \"date_of_birth\": \"1992-03-14\", \"country_of_residence\": \"Ivory Coast\", \"gender\": \"Female\", \"nationality\": \"Ivorian\", \"passport_or_id\": \"CI0123456\" },\n  \"caseData\": { \"destination\": \"France, Spain, Italy\", \"start_date\": \"2026-06-01\", \"end_date\": \"2026-06-15\", \"selected_plan_id\": 12 }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create sale (from confirmed case)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/sales", "host": ["{{baseUrl}}"], "path": ["sales"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"case_id\": 4821,\n  \"premium_amount\": 25000,\n  \"tax\": 0,\n  \"total\": 25000,\n  \"currency\": \"XOF\",\n  \"plan_price\": 25000\n}" }
          }
        },
        {
          "name": "List sales",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales", "host": ["{{baseUrl}}"], "path": ["sales"] } }
        },
