            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Sales ledger",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ledger?startDate=2026-01-01&endDate=2026-06-30&page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["ledger"],
              "query": [
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-06-30" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Sales ledger — CSV",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/ledger/export?startDate=2026-01-01&endDate=2026-06-30", "host": ["{{baseUrl}}"], "path": ["ledger","export"], "query": [{"key":"startDate","value":"2026-01-01"},{"key":"endDate","value":"2026-06-30"}] }
          }
        },
        {
          "name": "Invoices by region",
          "request": {
            "method": "GET",
            "url": {
