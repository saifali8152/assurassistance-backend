        },
        {
          "name": "List all cases (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/cases/all?page=1&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["cases","all"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "25" }]
            }
          }
        },
        {
          "name": "My cases (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/cases/my-cases?page=1&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["cases","my-cases"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "25" }]
            }
          }
        },
        {
          "name": "Pending sales",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cases/pending-sales", "host": ["{{baseUrl}}"], "path": ["cases","pending-sales"] }
