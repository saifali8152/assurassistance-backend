{
  "info": {
    "name": "AssurAssistance API",
    "description": "3rd-party integration collection. Set the {{baseUrl}} and {{apiKey}} (or {{jwt}}) collection variables in Postman before running. See /docs/INTEGRATION_GUIDE.md and /api/docs for the interactive reference.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "aas-public-api"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://backend-api.assurassistancepro.org/api", "type": "string" },
    { "key": "apiKey",  "value": "aas_live_REPLACE_ME", "type": "string" },
    { "key": "jwt",     "value": "REPLACE_ME", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{apiKey}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (in-house web app)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"agent@example.com\",\n  \"password\": \"...\"\n}" },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth","forgot-password"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"agent@example.com\" }" },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Verify reset code",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/verify-reset-code", "host": ["{{baseUrl}}"], "path": ["auth","verify-reset-code"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"agent@example.com\", \"code\": \"123456\" }" },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth","reset-password"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"agent@example.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"NewPass#2026\",\n  \"confirmPassword\": \"NewPass#2026\"\n}" },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Change password (logged in)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth","change-password"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"OldPass#2026\",\n  \"newPassword\": \"NewPass#2026\",\n  \"confirmPassword\": \"NewPass#2026\"\n}" },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        }
      ]
    },
    {
      "name": "Catalogue",
      "item": [
        {
          "name": "List plans",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/catalogue", "host": ["{{baseUrl}}"], "path": ["catalogue"] }
          }
        },
        {
          "name": "Create plan (admin JWT)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/catalogue", "host": ["{{baseUrl}}"], "path": ["catalogue"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"product_type\": \"Travel\",\n  \"name\": \"AGICO Worldwide 30 Days\",\n  \"coverage\": \"Medical: 60,000 EUR\",\n  \"flat_price\": 25000,\n  \"country_of_residence\": \"Burundi\",\n  \"route_type\": \"Outbound\",\n  \"currency\": \"XOF\",\n  \"theme_color\": \"#1E4D8B\",\n  \"extra_id_fields\": false\n}" },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        },
        {
          "name": "Update plan (admin JWT)",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/catalogue/12", "host": ["{{baseUrl}}"], "path": ["catalogue","12"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"product_type\": \"Travel\",\n  \"name\": \"AGICO Worldwide 45 Days\",\n  \"flat_price\": 30000,\n  \"currency\": \"XOF\"\n}" },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        },
        {
          "name": "Delete plan (admin JWT)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/catalogue/12", "host": ["{{baseUrl}}"], "path": ["catalogue","12"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        },
        {
          "name": "Upload partner logo (admin JWT)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/catalogue/12/partner-logo", "host": ["{{baseUrl}}"], "path": ["catalogue","12","partner-logo"] },
            "body": { "mode": "formdata", "formdata": [{ "key": "partner_logo", "type": "file", "src": [] }] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        },
        {
          "name": "Delete partner logo (admin JWT)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/catalogue/12/partner-logo", "host": ["{{baseUrl}}"], "path": ["catalogue","12","partner-logo"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] }
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "List cases",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cases", "host": ["{{baseUrl}}"], "path": ["cases"] }
