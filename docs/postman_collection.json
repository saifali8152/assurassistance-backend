        {
          "name": "Policy edit meta",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cases/4821/policy-edit-meta", "host": ["{{baseUrl}}"], "path": ["cases","4821","policy-edit-meta"] }
          }
        },
        {
          "name": "Create case",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/cases", "host": ["{{baseUrl}}"], "path": ["cases"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traveller\": {\n    \"first_name\": \"Aïcha\",\n    \"last_name\": \"Diallo\",\n    \"date_of_birth\": \"1992-03-14\",\n    \"country_of_residence\": \"Ivory Coast\",\n    \"gender\": \"Female\",\n    \"nationality\": \"Ivorian\",\n    \"passport_or_id\": \"CI0123456\",\n    \"phone\": \"+225 07 12 34 56 78\",\n    \"email\": \"aicha@example.com\"\n  },\n  \"caseData\": {\n    \"destination\": \"France, Spain\",\n    \"start_date\": \"2026-06-01\",\n    \"end_date\": \"2026-06-15\",\n    \"selected_plan_id\": 12\n  }\n}"
            }
