          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales/invoice/7912", "host": ["{{baseUrl}}"], "path": ["sales","invoice","7912"] } }
        },
        {
          "name": "Download certificate PDF",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales/certificate/7912", "host": ["{{baseUrl}}"], "path": ["sales","certificate","7912"] } }
        },
        {
          "name": "Certificate page data (JSON)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales/certificate/7912/page", "host": ["{{baseUrl}}"], "path": ["sales","certificate","7912","page"] } }
        },
        {
          "name": "Group invoices (ZIP)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales/group/grp_abc/invoices-zip", "host": ["{{baseUrl}}"], "path": ["sales","group","grp_abc","invoices-zip"] } }
