        {
          "name": "Group certificates (ZIP)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sales/group/grp_abc/certificates-zip", "host": ["{{baseUrl}}"], "path": ["sales","group","grp_abc","certificates-zip"] } }
        },
